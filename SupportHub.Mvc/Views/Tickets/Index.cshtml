@model List<SupportHub.Mvc.Models.ViewModels.Tickets.TicketListItemViewModel>
@{
    ViewData["Title"] = "Index";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Tickets</h1>
    <a class="btn btn-primary" asp-action="Create">Yeni Ticket</a>
</div>

@if(!Model.Any())
{
    <div class="alert alert-info">
        Henüz hiç ticket bulunmamaktadır.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Başlık</th>
                    <th>Durum</th>
                    <th>Öncelik</th>
                    <th>Oluşturulma Tarihi</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in Model)
                {
                    <tr>
                        <td>@ticket.Title</td>
                        <td>@ticket.Status</td>
                        <td>@ticket.Priority</td>
                        <td>@ticket.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm" role="group" aria-label="Ticket işlemleri">
                                <a class="btn btn-outline-primary"
                                   asp-action="Details"
                                   asp-route-id="@ticket.Id">
                                    Detay
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}