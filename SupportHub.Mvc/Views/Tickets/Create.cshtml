@model SupportHub.Mvc.Models.ViewModels.Tickets.CreateTicketViewModel

@{
    ViewData["Title"] = "Yeni Ticket";
}

<div class="page-shell">
    <div class="d-flex justify-content-between align-items-start gap-3 page-header">
        <div>
            <h1 class="h3 mb-1 page-title">Yeni Ticket Oluştur</h1>
        </div>

        <a class="btn btn-outline-secondary" asp-action="Index">
            Geri Dön
        </a>
    </div>

    <div class="card content-card">
        <div class="card-body">
            <form asp-action="Create" method="post" class="row g-4">
                <div class="col-12">
                    <label asp-for="Title" class="form-label">Başlık</label>
                    <input asp-for="Title" class="form-control" required />
                </div>

                <div class="col-12">
                    <label asp-for="Description" class="form-label">Açıklama</label>
                    <textarea asp-for="Description" rows="5" class="form-control" required></textarea>
                </div>

                <div class="col-md-6">
                    <label asp-for="Priority" class="form-label">Öncelik</label>
                    <select asp-for="Priority" asp-items="Model.PriorityOptions" class="form-select" required>
                        <option value="">Öncelik seçiniz</option>
                    </select>
                </div>

                <div class="col-12">
                    <button type="submit" class="btn btn-primary">Oluştur</button>
                </div>
            </form>
        </div>
    </div>
</div>
