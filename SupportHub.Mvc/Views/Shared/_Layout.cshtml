<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <title>@ViewData["Title"] - SupportHub.Mvc</title>
        <script type="importmap"></script>
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
        <link rel="stylesheet" href="~/SupportHub.Mvc.styles.css" asp-append-version="true"/>
    </head>
    <body class="d-flex flex-column min-vh-100">
        <header>
            <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm">
                <div class="container">
                    <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Tickets" asp-action="Index">
                        SupportHub
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Tickets" asp-action="Index">
                                    Tickets
                                </a>
                            </li>
                        </ul>
                        <div class="d-flex align-items-center">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <span class="navbar-text me-3">
                                    @User.Identity.Name
                                </span>

                                <form asp-controller="Auths" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        Logout
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a class="btn btn-outline-primary btn-sm" asp-controller="Auths" asp-action="Login">
                                    Login
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </nav>
        </header>
        <div class="container py-4 flex-grow-1">
            <main role="main">
                @RenderBody()
            </main>
        </div>

        <footer class="border-top text-muted py-3 mt-auto">
            <div class="container small">
                &copy; 2026 SupportHub
            </div>
        </footer>
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>
</html>